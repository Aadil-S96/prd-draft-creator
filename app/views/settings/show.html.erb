<div class="max-w-2xl">
  <h1 class="text-2xl font-bold text-slate-900 mb-1">Settings</h1>
  <p class="text-slate-500 text-sm mb-8">Manage your profile and integrations</p>

  <% if flash[:notice] %>
    <div class="mb-6 p-3 bg-emerald-50 border border-emerald-100 rounded-xl text-emerald-700 text-sm"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="mb-6 p-3 bg-red-50 border border-red-100 rounded-xl text-red-700 text-sm"><%= flash[:alert] %></div>
  <% end %>

  <%= form_with(model: current_user, url: settings_path, method: :patch, local: true) do |form| %>
    <!-- Profile -->
    <div class="bg-white rounded-2xl border border-slate-200 p-6 mb-6">
      <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-5">Profile</h2>
      <div class="flex items-center gap-4 mb-6 pb-6 border-b border-slate-100">
        <div class="w-14 h-14 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-xl">
          <%= current_user.display_name[0].upcase %>
        </div>
        <div>
          <p class="font-semibold text-slate-900"><%= current_user.display_name %></p>
          <p class="text-sm text-slate-500"><%= current_user.email %></p>
          <% if current_user.admin? %>
            <span class="inline-block mt-1 px-2 py-0.5 text-xs font-medium rounded-full bg-purple-100 text-purple-700">Admin</span>
          <% end %>
        </div>
      </div>
      <div>
        <%= form.label :name, "Display name", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
        <%= form.text_field :name, class: "w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition", placeholder: "Your name" %>
      </div>
    </div>

    <!-- Notion -->
    <div class="bg-white rounded-2xl border border-slate-200 p-6 mb-6">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider">Notion Integration</h2>
        <% if current_user.has_notion_config? %>
          <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full bg-emerald-50 text-emerald-700 border border-emerald-200">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Connected
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium rounded-full bg-amber-50 text-amber-700 border border-amber-200">
            Not configured
          </span>
        <% end %>
      </div>
      <p class="text-sm text-slate-500 mb-5">Connect your Notion workspace so PRDs are published to your own database.</p>

      <div class="space-y-4">
        <div>
          <%= form.label :notion_api_key, "API Key", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= form.text_field :notion_api_key, class: "w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition", placeholder: "ntn_..." %>
          <p class="text-xs text-slate-400 mt-1.5">From <a href="https://www.notion.so/profile/integrations" target="_blank" class="text-indigo-500 hover:text-indigo-600">notion.so/profile/integrations</a></p>
        </div>
        <div>
          <%= form.label :notion_database_id, "Database ID", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= form.text_field :notion_database_id, class: "w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition", placeholder: "31a51856c4b780be9a73f8c5365ea37b" %>
          <p class="text-xs text-slate-400 mt-1.5">The 32-character ID from your database URL</p>
        </div>
      </div>
    </div>

    <div class="flex justify-end">
      <%= form.submit "Save settings", class: "px-6 py-2.5 bg-indigo-600 text-white text-sm font-medium rounded-xl hover:bg-indigo-700 transition cursor-pointer shadow-sm" %>
    </div>
  <% end %>
</div>
