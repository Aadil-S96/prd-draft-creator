<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-slate-900">Projects</h1>
    <p class="text-slate-500 text-sm mt-1"><%= @projects.count %> PRD<%= @projects.count == 1 ? '' : 's' %> generated</p>
  </div>
</div>

<% if @projects.any? %>
  <div class="grid gap-4">
    <% @projects.each do |project| %>
      <%= link_to project_path(project), class: "block bg-white rounded-xl border border-slate-200 hover:border-indigo-300 hover:shadow-md hover:shadow-indigo-100/50 transition-all duration-200 p-5 group" do %>
        <div class="flex items-start justify-between mb-3">
          <h3 class="font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors truncate pr-4"><%= project.name %></h3>
          <div class="flex items-center gap-2 shrink-0">
            <span class="px-2.5 py-0.5 text-xs font-medium rounded-full <%= priority_badge_class(project.priority) %>"><%= project.priority %></span>
            <span class="px-2.5 py-0.5 text-xs font-medium rounded-full <%= status_badge_class(project.status) %>"><%= project.status.humanize %></span>
          </div>
        </div>

        <% if project.summary.present? %>
          <p class="text-sm text-slate-500 line-clamp-2 mb-3"><%= truncate(project.summary, length: 150) %></p>
        <% end %>

        <div class="flex items-center justify-between text-xs text-slate-400">
          <div class="flex items-center gap-4">
            <span class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
              <%= project.problem_type.humanize %>
            </span>
            <span class="flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              <%= project.user&.display_name || project.owner || 'Unassigned' %>
            </span>
          </div>
          <div class="flex items-center gap-3">
            <% if project.notion_url.present? %>
              <span class="text-indigo-400">Notion ↗</span>
            <% end %>
            <% if project.slack_thread_url.present? %>
              <span class="text-indigo-400">Slack ↗</span>
            <% end %>
            <span><%= project.created_at.strftime('%b %d, %Y') %></span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
    <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
    </div>
    <h3 class="text-lg font-semibold text-slate-900 mb-1">No PRDs yet</h3>
    <p class="text-slate-500 text-sm">Mention the bot in a Slack thread to create your first PRD</p>
  </div>
<% end %>
