<div class="mb-6">
  <%= link_to projects_path, class: "inline-flex items-center gap-1 text-sm text-slate-500 hover:text-slate-700 transition" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Projects
  <% end %>
</div>

<% if flash[:notice] %>
  <div class="mb-6 p-3 bg-emerald-50 border border-emerald-100 rounded-xl text-emerald-700 text-sm"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="mb-6 p-3 bg-red-50 border border-red-100 rounded-xl text-red-700 text-sm"><%= flash[:alert] %></div>
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Main content -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Header card -->
    <div class="bg-white rounded-2xl border border-slate-200 p-6">
      <div class="flex items-start justify-between mb-4">
        <h1 class="text-2xl font-bold text-slate-900"><%= @project.name %></h1>
        <div class="flex items-center gap-2">
          <span class="px-2.5 py-1 text-xs font-semibold rounded-full <%= priority_badge_class(@project.priority) %>"><%= @project.priority %></span>
          <span class="px-2.5 py-1 text-xs font-semibold rounded-full <%= status_badge_class(@project.status) %>"><%= @project.status.humanize %></span>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-slate-500">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
          <%= @project.problem_type.humanize %>
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <%= @project.owner || 'Unassigned' %>
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <%= @project.created_at.strftime('%B %d, %Y') %>
        </span>
      </div>

      <!-- External links -->
      <div class="flex gap-3 mt-5 pt-5 border-t border-slate-100">
        <% if @project.notion_url.present? %>
          <%= link_to @project.notion_url, target: "_blank", class: "inline-flex items-center gap-2 px-4 py-2 bg-slate-900 text-white text-sm font-medium rounded-lg hover:bg-slate-800 transition" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            View in Notion
          <% end %>
        <% end %>
        <% if @project.slack_thread_url.present? %>
          <%= link_to @project.slack_thread_url, target: "_blank", class: "inline-flex items-center gap-2 px-4 py-2 bg-white text-slate-700 text-sm font-medium rounded-lg border border-slate-200 hover:bg-slate-50 transition" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            Slack Thread
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Summary -->
    <% if @project.summary.present? %>
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-3">Summary</h2>
        <p class="text-slate-700 leading-relaxed"><%= @project.summary %></p>
      </div>
    <% end %>

    <!-- Hypothesis Tree -->
    <% if @project.hypothesis_tree.present? %>
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Hypothesis Tree</h2>
        <div class="space-y-3">
          <% @project.hypothesis_tree.each do |item| %>
            <div class="bg-slate-50 rounded-xl p-4">
              <p class="font-medium text-slate-800 mb-2"><%= item['hypothesis'] %></p>
              <% if item['sub_hypotheses'].present? %>
                <ul class="space-y-1 ml-4">
                  <% item['sub_hypotheses'].each do |sub| %>
                    <li class="text-sm text-slate-600 flex items-start gap-2">
                      <span class="text-indigo-400 mt-0.5">→</span>
                      <%= sub %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Update form -->
    <div class="bg-white rounded-2xl border border-slate-200 p-6">
      <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Update</h2>
      <%= form_with(model: @project, local: true, class: "space-y-4") do |form| %>
        <div>
          <%= form.label :status, "Status", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= form.select :status,
              Project.statuses.keys.map { |s| [s.humanize, s] },
              {},
              class: "w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>
        <div>
          <%= form.label :owner, "Owner", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= form.text_field :owner,
              class: "w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
              placeholder: "Owner name" %>
        </div>
        <%= form.submit "Save changes",
            class: "w-full px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-xl hover:bg-indigo-700 transition cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
